RISK_W1=0.30
RISK_W2=0.25
RISK_W3=0.20
RISK_W4=0.15
RISK_W5=0.10
FRESHNESS_D_DAYS=90


ASYNQ_CONCURRENCY=10
ASYNQ_QUEUES_DEFAULT=6
ASYNQ_QUEUES_CRITICAL=3
ASYNQ_QUEUES_LOW=1


CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


PUBLIC_API_URL=http://localhost:8080
PUBLIC_WS_URL=ws://localhost:8080


IMIP_ENABLED=false
IMIP_REPLY_TO=
