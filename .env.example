# ==========================================
# Workie — переменные окружения
# Скопируй в .env и заполни значения.
# ==========================================

# --- общие ---
APP_ENV=development               # development | production
APP_PORT=8080                     # порт HTTP API
APP_PUBLIC_URL=https://example.com  # публичный URL (для OAuth callback и webhooks)
APP_ENCRYPTION_KEY=               # 32 байта base64 для AES-256-GCM (генерируй: openssl rand -base64 32)
LOG_LEVEL=info                    # debug | info | warn | error

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=worktimesync
POSTGRES_PASSWORD=worktimesync_dev_pass
POSTGRES_DB=worktimesync
POSTGRES_SSLMODE=disable
DATABASE_URL=postgres://worktimesync:worktimesync_dev_pass@postgres:5432/worktimesync?sslmode=disable

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_SECRET=                       # сгенерируй: openssl rand -base64 64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h               # 7 дней

# --- GigaChat (Sber) ---
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_PERS  # GIGACHAT_API_PERS | GIGACHAT_API_CORP
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_MODEL=GigaChat            # GigaChat | GigaChat-Pro | GigaChat-Max

# --- OAuth провайдеры (спринт 2) ---
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=${APP_PUBLIC_URL}/api/v1/integrations/oauth/callback/google

OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_TENANT=common
OAUTH_MICROSOFT_REDIRECT_URL=${APP_PUBLIC_URL}/api/v1/integrations/oauth/callback/microsoft

OAUTH_YANDEX_CLIENT_ID=
OAUTH_YANDEX_CLIENT_SECRET=
OAUTH_YANDEX_REDIRECT_URL=${APP_PUBLIC_URL}/api/v1/integrations/oauth/callback/yandex

# --- Аналитика: веса риска R = w1(1-A) + w2*C + w3*L + w4*Z + w5*H ---
RISK_W1=0.30
RISK_W2=0.25
RISK_W3=0.20
RISK_W4=0.15
RISK_W5=0.10
FRESHNESS_D_DAYS=90               # максимально допустимый период без обновления

# --- Asynq ---
ASYNQ_CONCURRENCY=10
ASYNQ_QUEUES_DEFAULT=6
ASYNQ_QUEUES_CRITICAL=3
ASYNQ_QUEUES_LOW=1

# --- CORS (для dev) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend (передаётся в SvelteKit build) ---
PUBLIC_API_URL=http://localhost:8080
PUBLIC_WS_URL=ws://localhost:8080

# --- iMIP: календарные инвайты (.ics) + IMAP-приём RSVP ---
# При создании встречи в /scheduler всем участникам уходит .ics через SMTP.
# Gmail/Apple/Outlook показывают кнопки Accept/Decline. На «Accept» клиент
# шлёт REPLY-письмо на IMIP_REPLY_TO — мы пуллим IMAP и автоматически
# обновляем meeting_responses.status.
#
# Если IMIP_ENABLED=false — инвайты не шлём, IMAP-poller не стартует.
IMIP_ENABLED=false
IMIP_REPLY_TO=
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL=60s
