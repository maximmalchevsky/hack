

# Какой тэг образов тянем (по умолчанию latest).
IMAGE_TAG=latest

# --- общие ---
APP_ENV=production
APP_PORT=8080
APP_PUBLIC_URL=https://worktime.example.ru
APP_ENCRYPTION_KEY=      # openssl rand -base64 32
LOG_LEVEL=info

# --- PostgreSQL ---
# [docker-net] host = имя сервиса в compose, не localhost
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=worktimesync
POSTGRES_PASSWORD=       # openssl rand -base64 24
POSTGRES_DB=worktimesync
POSTGRES_SSLMODE=disable
# Полный URL — для api/worker/scheduler и migrate-job.
DATABASE_URL=postgres://worktimesync:CHANGE_ME@postgres:5432/worktimesync?sslmode=disable

# --- Redis ---
# [docker-net]
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_SECRET=              # openssl rand -base64 64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# --- GigaChat (Sber) ---
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_MODEL=GigaChat

# --- OAuth провайдеры ---
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=${APP_PUBLIC_URL}/api/v1/integrations/oauth/callback/google

OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_TENANT=common
OAUTH_MICROSOFT_REDIRECT_URL=${APP_PUBLIC_URL}/api/v1/integrations/oauth/callback/microsoft

OAUTH_YANDEX_CLIENT_ID=
OAUTH_YANDEX_CLIENT_SECRET=
OAUTH_YANDEX_REDIRECT_URL=${APP_PUBLIC_URL}/api/v1/integrations/oauth/callback/yandex

# --- Аналитика ---
RISK_W1=0.30
RISK_W2=0.25
RISK_W3=0.20
RISK_W4=0.15
RISK_W5=0.10
FRESHNESS_D_DAYS=90

# --- Asynq ---
ASYNQ_CONCURRENCY=10
ASYNQ_QUEUES_DEFAULT=6
ASYNQ_QUEUES_CRITICAL=3
ASYNQ_QUEUES_LOW=1

# --- CORS (на проде Caddy + same-origin, можно оставить пустым) ---
CORS_ALLOWED_ORIGINS=

# --- Email-уведомления (SMTP) ---
# Если не нужен — оставь SMTP_HOST пустым, транспорт сам отключится.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=WorkTime Sync <no-reply@worktime.example.ru>
SMTP_STARTTLS=true

# --- Telegram-бот ---
# Если не нужен — оставь TELEGRAM_BOT_TOKEN пустым.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
