# WorkTime Sync — reverse proxy
# В dev — слушаем :80, на проде раскоментируй секцию с доменом.

# === DEV (localhost) ===
:80 {
	@api path /api/* /swagger* /healthz /metrics /ws/*
	handle @api {
		reverse_proxy api:8080
	}
	handle {
		reverse_proxy web:3000
	}

	encode zstd gzip
	log {
		format console
	}
}

# === PROD (раскомментировать на VPS и заменить домен) ===
